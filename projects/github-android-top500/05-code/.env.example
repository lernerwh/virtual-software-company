# 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# GitHub Personal Access Token (必需)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# 服务端口
PORT=3001

# 缓存时长（小时）
CACHE_DURATION_HOURS=24

# 定时任务配置 (Cron表达式)
CRON_SCHEDULE=0 0 * * *

# 定时任务开关
SCHEDULER_ENABLED=true

# 日志级别
LOG_LEVEL=info

# CORS允许的源
CORS_ORIGIN=*

# Node环境
NODE_ENV=development
